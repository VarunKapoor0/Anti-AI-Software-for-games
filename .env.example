DATABASE_URL=                    # Pooled Postgres connection string
DATABASE_URL_DIRECT=             # Non-pooled, for migrations
UPSTASH_REDIS_REST_URL=          # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=        # Upstash Redis REST token
CRON_SECRET=                     # Random string matching Vercel cron config
SCRAPER_USER_AGENT=              # e.g. "AIGamesBot/0.1 (+https://yoursite.example/about)"
SITE_URL=                        # Canonical site URL, e.g. https://ai-in-games.example.com
